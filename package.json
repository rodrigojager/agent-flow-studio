{
  "name": "agent-flow-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "node --stack-size=8192 ./node_modules/typescript/bin/tsc --noEmit",
    "validate:flow": "tsx packages/flow-spec/src/cli.ts flows/reference-interview/agent.flow.json",
    "codegen:reference": "tsx packages/codegen-langgraph/src/cli.ts --flow flows/reference-interview/agent.flow.json --out generated/reference-interview-runtime",
    "codegen:sandbox": "tsx packages/codegen-langgraph/src/sandbox-cli.ts --flow flows/reference-interview/agent.flow.json --out generated/reference-interview-langgraph-sandbox",
    "codegen:manifest": "tsx packages/codegen-langgraph/src/manifest-cli.ts --manifest runtime.manifest.json --out generated/reference-runtime-bundle",
    "vm-image:bundle": "tsx tools/package-vm-image-bundle.ts",
    "vm-image:scaffold": "tsx tools/prepare-vm-image-scaffold.ts",
    "vm-image:homologate": "tsx tools/homologate-microvm-image.ts",
    "vm-image:microvm-recipe": "tsx tools/prepare-microvm-official-image-recipe.ts",
    "vm-image:microvm-register": "tsx tools/register-microvm-image-release.ts",
    "test:baseline": "python -m pytest -q examples/reference-interview-runtime",
    "test:generated": "python -m pytest -q generated/reference-interview-runtime",
    "test:manifest": "python -m pytest -q generated/reference-runtime-bundle/agents/reference-interview",
    "test:parity": "python tools/verify_runtime_parity.py",
    "test:mvp-main-path": "tsx tools/verify-mvp-main-path.ts",
    "test:portable-runtime": "tsx tools/verify-portable-runtime-artifact.ts",
    "test:portable-runtime-auth": "tsx tools/verify-portable-runtime-auth.ts",
    "test:portable-runtime-bundle": "tsx tools/verify-portable-runtime-bundle.ts",
    "test:collaboration-conflict-contract": "tsx tools/verify-collaboration-conflict-contract.ts",
    "test:onboarding-docs": "tsx tools/verify-onboarding-docs.ts",
    "test:local-models-runbook": "tsx tools/verify-local-models-runbook.ts",
    "test:release-privacy-audit-contract": "tsx tools/verify-release-privacy-audit-contract.ts",
    "test:external-integrations-homologation": "tsx tools/verify-external-integrations-homologation.ts",
    "test:isolation-levels-runbook": "tsx tools/verify-isolation-levels-runbook.ts",
    "test:multiagent-operations-runbook": "tsx tools/verify-multiagent-operations-runbook.ts",
    "test:expanded-plan-audit": "tsx tools/verify-expanded-plan-audit.ts",
    "test:expanded-plan-requirement-audit": "tsx tools/verify-expanded-plan-requirement-audit.ts",
    "test:expanded-plan-gate-matrix": "tsx tools/verify-expanded-plan-gate-matrix.ts",
    "test:expanded-plan-evidence-report": "tsx tools/verify-expanded-plan-audit.ts --self-test-report",
    "test:desktop": "npm run build:builder-ui && tsx tools/verify-electron-desktop.ts",
    "report:expanded-plan-evidence": "tsx tools/verify-expanded-plan-audit.ts --out .agent-flow/expanded-plan-evidence-report.json",
    "test:docker-runtime-smoke": "tsx tools/verify-generated-docker-runtime.ts",
    "test:builder-auth-corporate": "tsx tools/verify-builder-auth-corporate-contract.ts",
    "test:vm-image-manifest": "tsx tools/verify-vm-image-manifest-integrity.ts",
    "test:vm-image-bundle": "tsx tools/verify-vm-image-bundle.ts",
    "test:vm-image-scaffold": "tsx tools/verify-vm-image-scaffold.ts",
    "test:vm-microvm-image-scaffold": "tsx tools/verify-vm-microvm-image-scaffold.ts",
    "test:vm-image-real-smoke": "tsx tools/verify-vm-image-real-smoke.ts",
    "test:vm-microvm-real-smoke": "tsx tools/verify-vm-microvm-real-smoke.ts",
    "test:vm-microvm-homologation": "tsx tools/verify-vm-microvm-homologation.ts",
    "test:vm-microvm-official-recipe": "tsx tools/verify-vm-microvm-official-recipe.ts",
    "test:vm-microvm-release-registration": "tsx tools/verify-vm-microvm-release-registration.ts",
    "test:vm-reference-runner": "tsx tools/verify-vm-reference-runner.ts",
    "test:vm-qemu-runner": "tsx tools/verify-vm-qemu-runner-preflight.ts",
    "test:vm-microvm-runner": "tsx tools/verify-vm-microvm-runner.ts",
    "test:vm-guest-agent": "tsx tools/verify-vm-guest-agent.ts",
    "test:multiagent-postgres": "tsx tools/verify-multiagent-postgres-shared.ts",
    "test:builder-api": "tsx --test apps/builder-api/src/server.test.ts apps/builder-api/src/schema-patterns.test.ts apps/builder-api/src/provider-telemetry-alerts.test.mjs apps/builder-api/src/approved-runtime-manifest.test.mjs apps/builder-api/src/workspace-governance.test.mjs apps/builder-api/src/langsmith-cloud-deployment-automation.test.mjs apps/builder-api/src/studio-scenarios-conflict-review.test.mjs apps/builder-api/src/collaboration-conflicts.test.mjs",
    "test:ui-theme": "node tools/prepare-ui-audit-workspace.cjs && playwright install chromium && playwright test --config playwright.ui.config.cjs",
    "test:codegen": "tsx --test --test-concurrency=1 packages/codegen-langgraph/src/codegen.test.ts",
    "dev:builder-api": "tsx apps/builder-api/src/server.ts",
    "dev:builder-ui": "npm --workspace @agent-flow-builder/builder-ui run dev",
    "dev:desktop": "npm run build:builder-ui && electron apps/desktop/main.cjs",
    "build:builder-ui": "npm --workspace @agent-flow-builder/builder-ui run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "electron": "^43.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
