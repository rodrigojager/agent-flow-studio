{
  "id": "reference-interview",
  "name": "Agente de Referência",
  "version": "0.1.0",
  "runtime": "langgraph-python",
  "api": {
    "contract": "sessions-v1",
    "resourceName": "sessions",
    "autoStartOnCreate": false
  },
  "persistence": {
    "checkpointer": "postgres",
    "publicStore": "postgres",
    "cache": "redis"
  },
  "llm": {
    "adapter": "openai",
    "model": "gpt-4.1-mini",
    "apiKeyEnv": "OPENAI_API_KEY",
    "baseUrlEnv": "OPENAI_BASE_URL",
    "mockEnv": "MOCK_LLM"
  },
  "state": {
    "schemaRef": "schemas/session_state.schema.json"
  },
  "prompts": [
    {
      "id": "system",
      "path": "prompts/system.md",
      "version": "v1",
      "variables": [
        "session_id",
        "turn",
        "max_turns",
        "user_message",
        "recent_messages"
      ]
    }
  ],
  "schemas": [
    {
      "id": "session_state",
      "path": "schemas/session_state.schema.json"
    },
    {
      "id": "turn_output",
      "path": "schemas/turn_output.schema.json"
    }
  ],
  "nodes": [
    {
      "id": "start_node",
      "type": "start",
      "description": "Emite a primeira mensagem do agente de referência.",
      "position": {
        "x": 230,
        "y": 300
      }
    },
    {
      "id": "input_safety_check",
      "type": "safety_gate",
      "stage": "input",
      "position": {
        "x": 460,
        "y": 140
      }
    },
    {
      "id": "llm_step",
      "type": "llm_prompt",
      "promptId": "system",
      "llm": {
        "adapter": "openai",
        "model": "gpt-4.1-mini"
      },
      "position": {
        "x": 690,
        "y": 300
      }
    },
    {
      "id": "output_safety_check",
      "type": "safety_gate",
      "stage": "output",
      "position": {
        "x": 920,
        "y": 140
      }
    },
    {
      "id": "deterministic_gate",
      "type": "code",
      "handler": "deterministic_gate",
      "position": {
        "x": 1150,
        "y": 300
      }
    },
    {
      "id": "finish_node",
      "type": "end",
      "description": "Finaliza a sessão manualmente.",
      "position": {
        "x": 1380,
        "y": 140
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "start_node",
      "condition": "action == 'start'"
    },
    {
      "from": "start",
      "to": "input_safety_check",
      "condition": "action == 'turn'"
    },
    {
      "from": "start",
      "to": "finish_node",
      "condition": "action == 'finish'"
    },
    {
      "from": "input_safety_check",
      "to": "llm_step",
      "condition": "safety.decision == 'allow'"
    },
    {
      "from": "input_safety_check",
      "to": "end",
      "condition": "safety.blocked == true"
    },
    {
      "from": "llm_step",
      "to": "output_safety_check"
    },
    {
      "from": "output_safety_check",
      "to": "deterministic_gate"
    },
    {
      "from": "deterministic_gate",
      "to": "end"
    },
    {
      "from": "start_node",
      "to": "end"
    },
    {
      "from": "finish_node",
      "to": "end"
    }
  ]
}
