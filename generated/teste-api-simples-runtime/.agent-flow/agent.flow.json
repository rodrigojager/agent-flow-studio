{
  "id": "teste-api-simples",
  "name": "Teste Api Simples",
  "version": "0.1.0",
  "runtime": "langgraph-python",
  "api": {
    "contract": "sessions-v1",
    "resourceName": "sessions",
    "autoStartOnCreate": false
  },
  "persistence": {
    "checkpointer": "postgres",
    "publicStore": "postgres",
    "cache": "redis"
  },
  "llm": {
    "adapter": "openai",
    "model": "gpt-4.1-mini",
    "apiKeyEnv": "OPENAI_API_KEY",
    "baseUrlEnv": "OPENAI_BASE_URL",
    "mockEnv": "MOCK_LLM"
  },
  "state": {
    "schemaRef": "session_state"
  },
  "prompts": [
    {
      "id": "system",
      "path": "prompts/system.md",
      "version": "v1",
      "variables": [
        "session_id",
        "turn",
        "max_turns",
        "user_message",
        "recent_messages"
      ]
    }
  ],
  "schemas": [
    {
      "id": "session_state",
      "path": "schemas/session_state.schema.json"
    }
  ],
  "nodes": [
    {
      "id": "llm_prompt_1",
      "type": "llm_prompt",
      "promptId": "system",
      "llm": {
        "adapter": "openai",
        "model": "gpt-4.1-mini"
      },
      "position": {
        "x": 228.09523809523813,
        "y": 132.38095238095235
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "llm_prompt_1"
    },
    {
      "from": "llm_prompt_1",
      "to": "end"
    }
  ]
}
