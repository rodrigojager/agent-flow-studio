{
  "id": "reference-runtime",
  "name": "Reference Runtime",
  "version": "0.1.0",
  "packaging": "multiagent",
  "defaultLlm": {
    "adapter": "openai",
    "model": "gpt-4.1-mini",
    "apiKeyEnv": "OPENAI_API_KEY",
    "baseUrlEnv": "OPENAI_BASE_URL"
  },
  "agents": [
    {
      "id": "reference-interview",
      "flowPath": "flows/reference-interview/agent.flow.json",
      "routePrefix": "/reference-interview"
    }
  ],
  "orchestration": {
    "mode": "sequential",
    "entryAgentId": "reference-interview",
    "handoffs": [],
    "memoryPolicy": {
      "enabled": true,
      "persistence": "optional_jsonl",
      "defaultPersist": false,
      "defaultMemoryPath": "",
      "maxEntries": 64,
      "retentionRuns": 50,
      "maxPreviewChars": 500,
      "redactKeys": [
        "api_key",
        "authorization",
        "password",
        "secret",
        "token"
      ],
      "includeStepOutputs": true,
      "includeHandoffDecisions": true
    }
  }
}
