SERVICE_NAME=reference-interview-runtime
DATABASE_URL=postgresql+psycopg2://agent:agent@localhost:5433/agent_runtime
REDIS_URL=redis://localhost:6380/0
REDIS_ENABLED=true
USE_POSTGRES_CHECKPOINTER=true
MOCK_LLM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
LLM_ADAPTER=openai
LLM_MAX_RETRIES=2
AUTH_ENABLED=false
AGENT_API_KEY=
AUTO_CREATE_TABLES=true
LOG_LEVEL=INFO
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=reference-interview-runtime
